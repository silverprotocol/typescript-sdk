{
  "name": "@silverprotocol/google-adk",
  "version": "0.3.2",
  "description": "AgJSON normalizer for the official Google Agent Development Kit — @google/adk (ADK Event / Gemini Content.parts[] → AgEvent[]).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silverprotocol/typescript-sdk.git",
    "directory": "packages/google-adk"
  },
  "homepage": "https://github.com/silverprotocol/typescript-sdk#readme",
  "bugs": { "url": "https://github.com/silverprotocol/typescript-sdk/issues" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src", "!src/**/*.test.ts", "!dist/**/*.test.*"],
  "scripts": {
    "build": "tsc -b --force",
    "prepack": "rm -rf dist && tsc -b --force",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@silverprotocol/core": "workspace:*"
  },
  "peerDependencies": {
    "@google/adk": ">=1.0.0 <2"
  },
  "peerDependenciesMeta": {
    "@google/adk": {
      "optional": true
    }
  }
}
