{
  "name": "@silverprotocol/vercel-ai",
  "version": "0.3.5",
  "description": "AgJSON normalizer for the Vercel AI SDK (fullStream TextStreamPart \u2192 AgEvent[]).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silverprotocol/typescript-sdk.git",
    "directory": "packages/vercel-ai"
  },
  "homepage": "https://github.com/silverprotocol/typescript-sdk#readme",
  "bugs": {
    "url": "https://github.com/silverprotocol/typescript-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc -b --force",
    "prepack": "rm -rf dist && tsc -b --force",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@silverprotocol/core": "workspace:*"
  },
  "peerDependencies": {
    "ai": ">=6.0.0 <8"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  }
}
