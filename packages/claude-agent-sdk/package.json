{
  "name": "@silverprotocol/claude-agent-sdk",
  "version": "0.3.0",
  "description": "AgJSON normalizer for the Claude Agent SDK (SDKMessage → AgEvent[]) — the live path.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silverprotocol/typescript-sdk.git",
    "directory": "packages/claude-agent-sdk"
  },
  "homepage": "https://github.com/silverprotocol/typescript-sdk#readme",
  "bugs": { "url": "https://github.com/silverprotocol/typescript-sdk/issues" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src", "!src/**/*.test.ts", "!dist/**/*.test.*"],
  "scripts": {
    "build": "tsc -b --force",
    "prepack": "rm -rf dist && tsc -b --force",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@silverprotocol/core": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.2.76 <0.4"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.199",
    "@anthropic-ai/sdk": "^0.93.0"
  }
}
