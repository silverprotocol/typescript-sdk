{
  "name": "@silverprotocol/core",
  "version": "0.3.1",
  "description": "AgJSON core — the typed schema (AgInput / AgEvent / AgMessage), the Normalizer interface, and the normative reduce().",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silverprotocol/typescript-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://silverprotocol.io/AgJSON",
  "bugs": { "url": "https://github.com/silverprotocol/typescript-sdk/issues" },
  "keywords": [
    "agjson",
    "agent",
    "agents",
    "ai",
    "llm",
    "normalizer",
    "protocol",
    "streaming",
    "mcp",
    "claude",
    "openai"
  ],
  "publishConfig": { "access": "public" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src", "!src/**/*.test.ts", "!dist/**/*.test.*"],
  "scripts": {
    "build": "tsc -b",
    "prepack": "rm -rf dist && tsc -b --force",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.0.0"
  }
}
